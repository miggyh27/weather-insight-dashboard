# The target weather website URL to scrape. Defaults to timeanddate.com if not specified.
WEATHER_SITE_URL=https://www.timeanddate.com/weather/

# Delay in seconds between page visits to be ethical and respectful.
SCRAPE_DELAY_SECONDS=1.0

# WebDriver page load timeout in seconds.
PAGE_LOAD_TIMEOUT_SECONDS=30

# Maximum number of retry attempts for network or page load failures.
MAX_RETRIES=3
